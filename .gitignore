app/.packages
app/pubspec.lock
app/**/*.g.dart
app/**/*.freezed.dart
app/android/local.properties
app/android/.gradle/
app/android/app/debug/
app/android/app/release/
app/android/app/profile/
app/android/key.jks
app/ios/.symlinks/
app/ios/Pods/
app/ios/Flutter/Flutter.framework
app/ios/Flutter/Flutter.podspec
app/ios/Runner/GeneratedPluginRegistrant.*
app/macos/Flutter/GeneratedPluginRegistrant.*

# ── IDEs ────────────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.iml
*.iws
.DS_Store
Thumbs.db


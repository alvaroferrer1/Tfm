# MermaOps — Variables de entorno
# Copia este archivo como .env y rellena los valores

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=-100...

# App config
APP_ENV=development
APP_PORT=8000
STORE_ID=demo-store-001

# Geolocalización de la tienda (para predicción meteorológica con Open-Meteo)
# Si no se especifica, usa Madrid (40.4168, -3.7038)
STORE_LAT=40.4168
STORE_LON=-3.7038

# OpenFoodFacts (no requiere auth, pero se puede limitar)
OPENFOODFACTS_COUNTRY=es

# OpenAI (opcional — solo para transcripción de voz en Chuwi)
OPENAI_API_KEY=sk-...

# Langfuse — observabilidad de llamadas LLM (opcional pero recomendado para el TFM)
# Registro gratuito en https://cloud.langfuse.com — tarda 2 minutos
# Sin estas claves el sistema funciona igual, sin traza de observabilidad
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
